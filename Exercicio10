let valor = 100.01;

if (valor > 100 && valor < 200) {
    console.log("Você ganhou 10% de desconto, o valor final é: " + (valor - (valor * 0.10)));
}
else if (valor > 200) {
    console.log("Você ganhou 20% de desconto, o valor final é: " + (valor - (valor * 0.20)));
}
else {
    console.log("Não se aplica desconto");
}